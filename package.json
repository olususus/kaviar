{
  "name": "@sprawdzany/kaviar",
  "version": "1.2.1",
  "description": "Cloudflare KV cache helper with SWR, optional gzip compression, AES-GCM encryption, and tag invalidation.",
  "keywords": [
    "cloudflare",
    "workers",
    "kv",
    "cache",
    "swr",
    "stale-while-revalidate",
    "edge"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "how.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --watch --dts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "zod": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240320.1",
    "tsup": "^8.0.2",
    "typescript": "^5.4.3",
    "vitest": "^3.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/olususus/kaviar.git"
  },
  "homepage": "https://github.com/olususus/kaviar#readme",
  "bugs": {
    "url": "https://github.com/olususus/kaviar/issues"
  }
}
